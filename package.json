{
  "name": "hospital-mis",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@11.13.0",
  "engines": {
    "node": ">=22.13.0",
    "pnpm": ">=11.13.0"
  },
  "scripts": {
    "dev": "pnpm build:packages && concurrently -k -n API,WORKER,WEB -c auto \"pnpm --filter @hospital-mis/api dev\" \"pnpm --filter @hospital-mis/worker dev\" \"pnpm --filter @hospital-mis/web dev\"",
    "build:packages": "pnpm --filter './packages/**' build",
    "build": "pnpm -r --workspace-concurrency=4 --if-present build",
    "typecheck": "tsc -b --pretty false",
    "lint": "eslint .",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:integration": "vitest run --config vitest.integration.config.ts",
    "check": "pnpm lint && pnpm typecheck && pnpm test && pnpm build",
    "clean": "rimraf 'apps/*/dist' 'packages/*/dist' 'apps/web/.vite' coverage",
    "verify:running": "node scripts/verify-running-services.mjs",
    "db:migrate": "tsx scripts/database/migrate.ts",
    "db:seed": "tsx scripts/database/seed.ts",
    "db:reset": "tsx scripts/database/reset.ts",
    "db:test": "vitest run packages/database/src/testing/schema.test.ts"
  },
  "devDependencies": {
    "@eslint/js": "10.0.1",
    "@testing-library/jest-dom": "6.9.1",
    "@testing-library/react": "16.3.2",
    "@types/node": "26.1.1",
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "concurrently": "10.0.3",
    "cross-env": "10.1.0",
    "eslint": "10.7.0",
    "eslint-plugin-react-hooks": "7.1.1",
    "eslint-plugin-react-refresh": "0.5.3",
    "globals": "17.7.0",
    "jsdom": "29.1.1",
    "prettier": "3.9.5",
    "rimraf": "6.1.3",
    "tsx": "4.23.1",
    "typescript": "6.0.3",
    "typescript-eslint": "8.64.0",
    "vitest": "4.1.10"
  },
  "dependencies": {
    "@hospital-mis/database": "workspace:*",
    "mongoose": "9.7.4"
  }
}
