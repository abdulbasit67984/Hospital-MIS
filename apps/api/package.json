    "@hospital-mis/permissions": "workspace:*",
    "@hospital-mis/shared": "workspace:*",
    "@hospital-mis/validation": "workspace:*",
    "cors": "2.8.6",
    "dotenv": "17.4.2",
    "express": "5.2.1",
    "express-rate-limit": "8.5.2",
    "helmet": "8.3.0",
    "pino-http": "11.0.0",
    "socket.io": "4.8.3",
    "swagger-ui-express": "5.0.1",
    "zod": "4.4.3"
  },
  "devDependencies": {
    "@types/cors": "2.8.19",
    "@types/express": "5.0.6",
    "@types/supertest": "7.2.0",
    "@types/swagger-ui-express": "4.1.8",
    "cross-env": "10.1.0",
    "supertest": "7.2.2",
    "tsx": "4.23.1"
  }
