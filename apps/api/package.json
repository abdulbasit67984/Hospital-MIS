{
  "name": "@hospital-mis/api",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "cross-env NODE_OPTIONS=--conditions=development tsx watch src/server.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/server.js",
    "typecheck": "tsc -b --pretty false",
    "seed:admin": "cross-env NODE_OPTIONS=--conditions=development tsx src/scripts/seed-admin.ts",
    "seed:identity-access": "cross-env NODE_OPTIONS=--conditions=development tsx src/scripts/seed-identity-access.ts",
    "seed:facility-configuration-access": "cross-env NODE_OPTIONS=--conditions=development tsx src/scripts/seed-facility-configuration-access.ts",
    "seed:facility-configuration": "cross-env NODE_OPTIONS=--conditions=development tsx src/scripts/seed-facility-configuration.ts",
    "seed:patient-guardian-access": "cross-env NODE_OPTIONS=--conditions=development tsx src/scripts/seed-patient-guardian-access.ts",
    "seed:registration-queue-access": "cross-env NODE_OPTIONS=--conditions=development tsx src/scripts/seed-registration-queue-access.ts",
    "seed:formulary-prescription-access": "cross-env NODE_OPTIONS=--conditions=development tsx src/scripts/seed-formulary-prescription-access.ts",
    "seed:laboratory-access": "cross-env NODE_OPTIONS=--conditions=development tsx src/scripts/seed-laboratory-access.ts",
    "test:laboratory": "vitest run src/modules/laboratory/tests",
    "test:facility-integration": "cross-env RUN_FACILITY_CONFIGURATION_INTEGRATION_TESTS=true vitest run --config ../../vitest.integration.config.ts src/modules/facility/tests/facility-configuration.integration.test.ts",
    "test:formulary-prescriptions": "vitest run src/modules/formulary-prescriptions/tests"
  },
  "dependencies": {
    "@hospital-mis/config": "workspace:*",
    "@hospital-mis/database": "workspace:*",
    "@hospital-mis/permissions": "workspace:*",
    "@hospital-mis/shared": "workspace:*",
    "@hospital-mis/validation": "workspace:*",
    "cors": "2.8.6",
    "decimal.js": "10.6.0",
    "dotenv": "17.4.2",
    "express": "5.2.1",
    "express-rate-limit": "8.5.2",
    "helmet": "8.3.0",
    "luxon": "3.7.2",
    "mongoose": "9.7.4",
    "pino-http": "11.0.0",
    "socket.io": "4.8.3",
    "swagger-ui-express": "5.0.1",
    "zod": "4.4.3"
  },
  "devDependencies": {
    "@types/cors": "2.8.19",
    "@types/express": "5.0.6",
    "@types/luxon": "3.7.2",
    "@types/supertest": "7.2.0",
    "@types/swagger-ui-express": "4.1.8",
    "cross-env": "10.1.0",
    "supertest": "7.2.2",
    "tsx": "4.23.1"
  }
}