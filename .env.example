NODE_ENV=development

API_PORT=4000
CORS_ORIGINS=http://localhost:5173,http://localhost:3000
SOCKET_IO_PATH=/socket.io
READINESS_TIMEOUT_MS=3000

MONGODB_URI=mongodb://127.0.0.1:27017/hospital_mis
MONGODB_APP_NAME=hospital-mis-api
MONGODB_SERVER_SELECTION_TIMEOUT_MS=5000

LOG_LEVEL=info

WORKER_ID=worker-local-1
WORKER_HEALTH_INTERVAL_MS=15000
WORKER_SHUTDOWN_TIMEOUT_MS=10000

VITE_API_BASE_URL=/api/v1
VITE_SOCKET_URL=http://localhost:4000
VITE_SOCKET_PATH=/socket.io

# Authentication
# Replace all three secrets with different, cryptographically random values.
AUTH_ACCESS_TOKEN_SECRET=development-access-token-secret-change-me-2026
AUTH_REFRESH_TOKEN_HASH_SECRET=development-refresh-hash-secret-change-me-2026
AUTH_PASSWORD_PEPPER=development-password-pepper-change-me-2026

AUTH_ACCESS_TOKEN_KEY_ID=hmis-access-v1
AUTH_ISSUER=hospital-mis-api
AUTH_AUDIENCE=hospital-mis-web

# 15 minutes
AUTH_ACCESS_TOKEN_TTL_SECONDS=900

# Refresh-token and session lifetime
AUTH_REFRESH_TOKEN_TTL_DAYS=30

# Expired and revoked session records are retained before TTL cleanup.
AUTH_SESSION_RETENTION_DAYS=90

# Argon2id configuration
AUTH_PASSWORD_MEMORY_KIB=65536
AUTH_PASSWORD_TIME_COST=3
AUTH_PASSWORD_PARALLELISM=1
AUTH_PASSWORD_HASH_LENGTH=32
AUTH_PASSWORD_MIN_LENGTH=12
AUTH_PASSWORD_MAX_LENGTH=128

# Facility and configuration security
#
# Each encryption key must be a base64-encoded 32-byte key.
# Keep old versions while any stored value still references them.
# Generate a key with:
# node -e "console.log(require('node:crypto').randomBytes(32).toString('base64'))"
FACILITY_CONFIGURATION_ENCRYPTION_ACTIVE_KEY_VERSION=v1
FACILITY_CONFIGURATION_ENCRYPTION_KEYS_JSON={"v1":"MDEyMzQ1Njc4OWFiY2RlZjAxMjM0NTY3ODlhYmNkZWY="}

# Used only for keyed hashes. It must not match an encryption key or auth secret.
FACILITY_CONFIGURATION_HASH_SECRET=development-facility-setting-hash-secret-change-me-2026

FACILITY_CONFIGURATION_CACHE_DEFAULT_TTL_SECONDS=300
FACILITY_CONFIGURATION_CACHE_MAX_ENTRIES=10000

ALLOW_DATABASE_RESET=false